rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core helper functions for security
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Robust check: ensures document exists before accessing properties to prevent evaluation crashes
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && (
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'Active' ||
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'Head Admin'
      );
    }

    function isHeadAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'Head Admin';
    }

    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // BOOTSTRAP RULE: Allow the master email to create or update their own admin record to initialize the system.
      allow create, update: if isOwner(userId) && (isHeadAdmin() || request.auth.token.email == 'admin@vidyaeducare.com');
      // Allow Head Admins to delete others, or users to delete their own record (cleaning up during setup).
      allow delete: if isHeadAdmin() || isOwner(userId);
    }

    match /users/{userId} {
      // Allow general read for profile resolution and setup checks
      allow read: if isOwner(userId) || isAdmin() || isAuthenticated();
      // Allow owners to write their own profile (crucial for signup/setup)
      allow write: if isOwner(userId) || isAdmin();
    }

    match /wallets/{userId} {
      // Allow owners to see and manage their wallets (required for store/referral logic)
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /students/{studentId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.parentId == request.auth.uid || isAdmin()
      );
    }
    
    match /transactions/{txId} {
        // Essential: Allow users to list/query their own transactions for dashboards
        allow read: if isAuthenticated() && (
          resource == null || resource.data.user == request.auth.uid || isAdmin()
        );
        allow create: if isAuthenticated() && request.resource.data.user == request.auth.uid;
        allow update: if isHeadAdmin();
    }

    match /chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isHeadAdmin();
    }

    match /activationCodes/{userId} {
        allow read, write: if isOwner(userId) || isAdmin();
    }

    match /testSets/{testSetId} {
        allow read: if true;
        allow write: if isHeadAdmin();
    }

    match /scheduledTests/{testId} {
        allow read: if true;
        allow write: if isHeadAdmin();
    }

    match /testResults/{resultId} {
        allow create: if isAuthenticated();
        allow read: if isAuthenticated() && (
          resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.students || isAdmin()
        );
    }

    match /leaderboard/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated(); 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated();
    }
    
    match /notifications/{notifId} {
        allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
        allow write: if isAdmin();
    }
    
    match /referbolt/{userId} {
        allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /clients/{clientId} {
        allow read: if isAuthenticated() && (resource.data.referrerId == request.auth.uid || isAdmin());
        allow write: if isAdmin();
    }
  }
}