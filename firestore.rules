rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core helper functions for security
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // BOOTSTRAP HELPER: Identifies the master accounts allowed to initialize the project
    function isBootstrap() {
      return isAuthenticated() && 
             (request.auth.token.email.lower() == 'admin@vidyaeducare.com' || 
              request.auth.token.email.lower() == 'student@vidyaeducare.com');
    }

    // Robust check: ensures document exists before accessing properties to prevent evaluation crashes
    function isAdmin() {
      if (!isAuthenticated()) return false;
      if (request.auth.token.email.lower() == 'admin@vidyaeducare.com') return true; 
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && (
             get(adminPath).data.status == 'Active' ||
             get(adminPath).data.role == 'Head Admin'
      );
    }

    function isHeadAdmin() {
      if (!isAuthenticated()) return false;
      if (request.auth.token.email.lower() == 'admin@vidyaeducare.com') return true;

      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && get(adminPath).data.role == 'Head Admin';
    }

    match /admins/{userId} {
      allow read: if isAuthenticated();
      // Allow bootstrap email or existing Head Admin to create/update/delete records
      allow write, delete: if isBootstrap() || (isOwner(userId) && isHeadAdmin());
    }

    match /users/{userId} {
      allow list, get: if isAuthenticated();
      allow write: if isBootstrap() || isOwner(userId) || isAdmin();
    }

    match /wallets/{userId} {
      allow list: if isAuthenticated();
      allow get: if isOwner(userId) || isAdmin();
      allow write: if isBootstrap() || isOwner(userId) || isAdmin();
    }

    match /students/{studentId} {
      allow list: if isAuthenticated();
      allow get: if isAuthenticated();
      allow write: if isBootstrap() || isAdmin() || (resource != null && resource.data.parentId == request.auth.uid);
    }
    
    match /transactions/{txId} {
        allow list: if isAuthenticated();
        allow get: if isAuthenticated() && (
          resource == null || resource.data.user == request.auth.uid || isAdmin()
        );
        allow create: if isAuthenticated() && request.resource.data.user == request.auth.uid;
        allow update: if isHeadAdmin();
    }

    match /chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isHeadAdmin() || isBootstrap();
    }

    match /activationCodes/{userId} {
        allow read, write: if isOwner(userId) || isAdmin() || isBootstrap();
    }

    match /testSets/{testSetId} {
        allow read: if true;
        allow write: if isHeadAdmin() || isBootstrap();
    }

    match /scheduledTests/{testId} {
        allow read: if true;
        allow write: if isHeadAdmin() || isBootstrap();
    }

    match /testResults/{resultId} {
        allow create: if isAuthenticated();
        allow read: if isAuthenticated() && (
          isAdmin() || resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.students
        );
    }

    match /leaderboard/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated(); 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if isAdmin() || isBootstrap();
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated();
    }
    
    match /notifications/{notifId} {
        allow list: if isAuthenticated();
        allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
        allow write: if isAdmin() || isBootstrap();
    }
    
    match /referbolt/{userId} {
        allow read, write: if isOwner(userId) || isAdmin() || isBootstrap();
    }
    
    match /clients/{clientId} {
        allow list: if isAuthenticated();
        allow get: if isAuthenticated() && (resource.data.referrerId == request.auth.uid || isAdmin());
        allow write: if isAdmin() || isBootstrap();
    }
  }
}