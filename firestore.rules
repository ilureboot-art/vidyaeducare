
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow admins to read their own profile to check status
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Writing to the admins collection should be more restricted,
      // e.g., only by other head admins. For now, we'll keep it locked down.
      allow write: if false; 
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /wallets/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /students/{studentId} {
      // Allow parent to read/write their own students
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/students/$(studentId)).data.parentId == request.auth.uid;
    }
    
    match /transactions/{txId} {
        // Users can read their own transactions
        allow read: if request.auth != null && get(/databases/$(database)/documents/transactions/$(txId)).data.user == request.auth.uid;
        // Creating transactions is handled by secure logic (e.g. backend functions or specific client actions)
        allow create: if request.auth != null;
        // Admins can update status, but users cannot
        allow update: if false;
    }

    match /chats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if false; // Only admins from a backend should write
    }

    match /activationCodes/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /testSets/{testSetId} {
        allow read: if true; // Test questions are public
        allow write: if false;
    }

    match /scheduledTests/{testId} {
        allow read: if true;
        allow write: if false;
    }

    match /testResults/{resultId} {
        allow read, write: if request.auth != null;
    }

    match /leaderboard/{resultId} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if request.auth != null; // Allow logged in users to register (updates players array)
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if request.auth != null;
    }
  }
}
