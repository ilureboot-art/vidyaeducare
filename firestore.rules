rules_version = '2';

/**
 * Vidya EduCare - Hardened Production Infrastructure Rules
 * Target Instance: vidyaeducaredatabase
 * Priority: High-Speed Authorization & Conflict Resolution
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---

    function signedIn() {
      return request.auth != null;
    }

    function isMaster() {
      // Direct token access for speed and reliability during initialization
      return signedIn() && 
        (request.auth.token.email == 'admin@vidyaeducare.com' || 
         request.auth.token.email == 'headadmin@vidyaeducare.com');
    }

    function isAdmin() {
      if (!signedIn()) return false;
      if (isMaster()) return true;
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath);
    }

    // --- SUPREME OVERRIDE ---
    // Master Admin has full access to the entire database hierarchy.
    // This is placed at the top for maximum authority resolution speed.
    match /{allPaths=**} {
      allow read, write: if isMaster();
    }

    // --- GLOBAL CONFIGURATIONS (Read Optimized) ---
    // These must be readable by everyone to allow the UI to initialize (prices, subjects, etc.)
    match /configs/{document=**} {
      allow read: if true; 
      allow write: if isAdmin() || (signedIn() && request.auth.token.email == 'admin@vidyaeducare.com');
    }

    // --- ROLE RESOLUTION & ADMIN LISTING ---
    match /admins/{uid} {
      allow read: if signedIn();
      // Allow the master account to initialize its own record during setup
      allow write: if isMaster() || (signedIn() && request.auth.uid == uid && request.auth.token.email == 'admin@vidyaeducare.com');
    }

    match /admins/{document=**} {
      allow read, list: if signedIn();
      allow write: if isMaster();
    }

    // --- USER PRIVATE DATA ---

    match /users/{uid} {
      allow read: if signedIn();
      // Explicitly allow owner or master admin to manage the user record
      allow create: if signedIn() && (isMaster() || request.auth.uid == uid); 
      allow update, delete: if signedIn() && (isMaster() || request.auth.uid == uid || isAdmin());
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if signedIn();
      allow update: if isAdmin() || isOwner(uid);
    }

    match /activationCodes/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /chats/{uid} {
      allow read, write, list: if isOwner(uid) || isAdmin();
      match /messages/{mid} {
        allow read, write, list: if isOwner(uid) || isAdmin();
      }
    }

    match /referbolt/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /students/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin() || (resource != null && (resource.data.parentId == request.auth.uid)) || (request.resource != null && (request.resource.data.parentId == request.auth.uid));
    }
    
    match /transactions/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && resource.data.user == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.user == request.auth.uid);
      allow update: if isAdmin();
    }

    match /testSets/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }

    match /scheduledTests/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }

    match /testResults/{id} {
      allow read, list: if signedIn();
      allow create: if signedIn();
    }

    match /leaderboard/{id} {
      allow read, list: if true;
      allow write: if signedIn();
    }

    match /quizClashTournaments/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /quizClashResults/{id} {
      allow read, list: if true;
      allow write: if signedIn();
    }
    
    match /notifications/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid) || (resource != null && resource.data.userId == 'admin' && isAdmin()));
      allow write: if isAdmin();
    }
    
    match /clients/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }
  }
}