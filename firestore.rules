
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isHeadAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'Head Admin';
    }

    match /admins/{userId} {
      // Allow any authenticated user to read the admins collection to verify roles.
      // Write access remains restricted, so this is secure.
      allow read: if request.auth != null;
      allow list, update, delete: if isHeadAdmin();
      // Lock down creation to only Head Admins
      allow create: if isHeadAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow list: if isHeadAdmin();
    }

    match /wallets/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /students/{studentId} {
      // Allow parent to read/write their own students
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/students/$(studentId)).data.parentId == request.auth.uid;
    }
    
    match /transactions/{txId} {
        // Users can read their own transactions
        allow read: if request.auth != null && get(/databases/$(database)/documents/transactions/$(txId)).data.user == request.auth.uid;
        // Admins can list all transactions for analytics
        allow list: if isHeadAdmin();
        // Users can create their own transactions (e.g., deposit/withdrawal requests)
        allow create: if request.auth != null && request.resource.data.user == request.auth.uid;
        // Only Admins can update status (e.g., from Pending to Completed)
        allow update: if isHeadAdmin();
    }

    match /chats/{userId} {
      allow read, write: if isOwner(userId);
      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /configs/{configId} {
      allow read: if true; // Configs are public
      allow write: if isHeadAdmin();
    }

    match /activationCodes/{userId} {
        allow read, write: if isOwner(userId);
    }

    match /testSets/{testSetId} {
        allow read: if true; // Test questions are public
        allow write: if isHeadAdmin();
    }

    match /scheduledTests/{testId} {
        allow read: if true; // Schedule is public
        allow write: if isHeadAdmin();
    }

    match /testResults/{resultId} {
        // A user can write their own test result
        allow create: if request.auth != null && request.resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.students;
        // Only the user who owns the student can read the result.
        allow read: if request.auth != null && get(/databases/$(database)/documents/testResults/$(resultId)).data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.students;
    }

    match /leaderboard/{resultId} {
        allow read: if true; // Leaderboard is public
        // Users can write their own results to the leaderboard
        allow write: if request.auth != null; 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if isHeadAdmin() || request.auth != null; // Admins can create, users can update by registering
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if request.auth != null; // Users can write their own results
    }
  }
}
