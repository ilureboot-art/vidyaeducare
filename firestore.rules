
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is a Head Admin
    function isHeadAdmin(userId) {
      return get(/databases/$(database)/documents/admins/$(userId)).data.role == 'Head Admin';
    }

    match /admins/{userId} {
      // Any authenticated user can read their own admin doc to verify their role/status
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow a user to CREATE their own admin document ONLY IF they are setting their role to 'Head Admin'.
      // This is essential for bootstrapping the first admin.
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.role == 'Head Admin';
      
      // Only Head Admins can list, update, or delete other admin docs.
      allow list, update, delete: if request.auth != null && isHeadAdmin(request.auth.uid);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /wallets/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /students/{studentId} {
      // Allow parent to read/write their own students
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/students/$(studentId)).data.parentId == request.auth.uid;
    }
    
    match /transactions/{txId} {
        // Users can read their own transactions
        allow read: if request.auth != null && get(/databases/$(database)/documents/transactions/$(txId)).data.user == request.auth.uid;
        // Creating transactions is handled by secure logic (e.g. backend functions or specific client actions)
        allow create: if request.auth != null;
        // Admins can update status, but users cannot
        allow update: if request.auth != null && isHeadAdmin(request.auth.uid);
    }

    match /chats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if request.auth != null && isHeadAdmin(request.auth.uid);
    }

    match /activationCodes/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /testSets/{testSetId} {
        allow read: if true; // Test questions are public
        allow write: if request.auth != null && isHeadAdmin(request.auth.uid);
    }

    match /scheduledTests/{testId} {
        allow read: if true;
        allow write: if request.auth != null && isHeadAdmin(request.auth.uid);
    }

    match /testResults/{resultId} {
        allow read, write: if request.auth != null;
    }

    match /leaderboard/{resultId} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if request.auth != null;
    }
  }
}
