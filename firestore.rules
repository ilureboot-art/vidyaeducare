rules_version = '2';

/**
 * Vidya EduCare - Global Infrastructure Rules
 * Target Instance: vidyaeducaredatabase
 * Deployment Salt: V41_CORE_SYNC_RESOLVED
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      // Direct validation for the master deployment identity
      // Includes both the hardcoded UID and the known admin email
      return isAuthenticated() && (
        request.auth.uid == '1JgG0oF1D6YREaxOCSGedIfpQZ42' ||
        (request.auth.token.email != null && request.auth.token.email == 'admin@vidyaeducare.com')
      );
    }

    function isAdmin() {
      if (!isAuthenticated()) return false;
      if (isMasterAdmin()) return true;
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && (
        get(adminPath).data.status == 'Active' || 
        get(adminPath).data.role == 'Head Admin'
      );
    }

    function isHeadAdmin() {
      if (!isAuthenticated()) return false;
      if (isMasterAdmin()) return true;
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && get(adminPath).data.role == 'Head Admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- PRIORITY RULES: Global Infrastructure ---

    // Placed at the absolute top to ensure unrestricted access to system metadata.
    // These documents contain public configurations like subjects, standards, and store prices.
    match /configs/{configId} {
      allow read, get, list: if true;
      allow write: if isAdmin();
    }

    // --- RESOURCE RULES ---

    match /admins/{userId} {
      allow read, list: if isAuthenticated();
      allow write: if isHeadAdmin() || isOwner(userId);
    }

    match /users/{userId} {
      allow read, list: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    match /wallets/{userId} {
      allow read, list: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    match /students/{studentId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin() || (resource != null && resource.data.parentId == request.auth.uid);
    }
    
    match /transactions/{txId} {
        allow read, list: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isHeadAdmin();
    }

    match /chats/{userId} {
      allow list: if isAdmin();
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /activationCodes/{userId} {
        allow read, write, list: if isOwner(userId) || isAdmin();
    }

    match /testSets/{testSetId} {
        allow read, list, get: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /scheduledTests/{testId} {
        allow read, list, get: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /testResults/{resultId} {
        allow create, read, list: if isAuthenticated();
    }

    match /leaderboard/{resultId} {
        allow read, list: if true;
        allow write: if isAuthenticated(); 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read, list, get: if true;
        allow write: if isAdmin();
    }

    match /quizClashResults/{resultId} {
        allow read, list, get: if true;
        allow write: if isAuthenticated();
    }
    
    match /notifications/{notifId} {
        allow read, list, get: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /referbolt/{userId} {
        allow read, write, list: if isOwner(userId) || isAdmin();
    }
    
    match /clients/{clientId} {
        allow read, list, get: if isAuthenticated();
        allow write: if isAdmin();
    }

    // --- SUPREME MASTER OVERRIDE ---
    match /{allPaths=**} {
      allow read, write: if isMasterAdmin();
    }
  }
}