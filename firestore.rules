rules_version = '2';

/**
 * Vidya EduCare - Hardened Production Infrastructure Rules
 * Target Instance: vidyaeducaredatabase
 * Priority: Absolute Master Admin Bypass & Resilient Auth Handshake
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Core Identity Functions ---

    function signedIn() {
      return request.auth != null;
    }

    function isMaster() {
      // Simplistic but high-priority check for the master admin email.
      // This ensures that system initialization (Map to Database) can always proceed.
      return signedIn() && 
        request.auth.token.email.lower() in ['admin@vidyaeducare.com', 'headadmin@vidyaeducare.com'];
    }

    function isAdmin() {
      if (!signedIn()) return false;
      if (isMaster()) return true;
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- SUPREME OVERRIDE (PRIORITY 1) ---
    // Master Admin bypasses all checks to ensure infrastructure can always be mapped/synced.
    match /{allPaths=**} {
      allow read, write: if isMaster();
    }

    // --- GLOBAL CONFIGURATIONS ---
    match /configs/{document=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- USER PRIVATE DATA ---

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && (request.auth.uid == uid || isMaster()); 
      allow update, delete: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if signedIn() && (isMaster() || request.auth.uid == uid);
      allow update: if isAdmin() || isOwner(uid);
    }

    match /activationCodes/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn();
      allow write: if isMaster();
    }

    match /chats/{uid} {
      allow read, write, list: if isOwner(uid) || isAdmin();
      match /messages/{mid} {
        allow read, write, list: if isOwner(uid) || isAdmin();
      }
    }

    match /referbolt/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /students/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin() || (resource != null && (resource.data.parentId == request.auth.uid)) || (request.resource != null && (request.resource.data.parentId == request.auth.uid));
    }
    
    match /transactions/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && resource.data.user == request.auth.uid));
      allow create: if signedIn() && (request.resource.data.user == request.auth.uid);
      allow update: if isAdmin();
    }

    match /testSets/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }

    match /scheduledTests/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }

    match /testResults/{id} {
      allow read, list: if signedIn();
      allow create: if signedIn();
    }

    match /leaderboard/{id} {
      allow read, list: if true;
      allow write: if signedIn();
    }

    match /quizClashTournaments/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /quizClashResults/{id} {
      allow read, list: if true;
      allow write: if signedIn();
    }
    
    match /notifications/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin')));
      allow write: if isAdmin();
    }
    
    match /clients/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }
  }
}