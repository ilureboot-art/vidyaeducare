
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Simplified role check for better performance and reliability
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isHeadAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'Head Admin';
    }

    match /admins/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete, list: if isHeadAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow list: if isAdmin();
    }

    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /students/{studentId} {
      allow read, write: if request.auth != null && (
        resource == null || resource.data.parentId == request.auth.uid || isAdmin()
      );
    }
    
    match /transactions/{txId} {
        allow read: if request.auth != null && (
          resource == null || resource.data.user == request.auth.uid || isAdmin()
        );
        allow list: if isAdmin();
        allow create: if request.auth != null && request.resource.data.user == request.auth.uid;
        allow update: if isHeadAdmin();
    }

    match /chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isHeadAdmin();
    }

    match /activationCodes/{userId} {
        allow read, write: if isOwner(userId) || isAdmin();
    }

    match /testSets/{testSetId} {
        allow read: if true;
        allow write: if isHeadAdmin();
    }

    match /scheduledTests/{testId} {
        allow read: if true;
        allow write: if isHeadAdmin();
    }

    match /testResults/{resultId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null && (resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.students || isAdmin());
    }

    match /leaderboard/{resultId} {
        allow read: if true;
        allow write: if request.auth != null; 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if isAdmin() || request.auth != null;
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if request.auth != null;
    }
    
    match /notifications/{notifId} {
        allow read: if request.auth != null && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
        allow write: if isAdmin();
    }
    
    match /referbolt/{userId} {
        allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /clients/{clientId} {
        allow read: if request.auth != null && (resource.data.referrerId == request.auth.uid || isAdmin());
        allow write: if isAdmin();
    }
  }
}
