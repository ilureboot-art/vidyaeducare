rules_version = '2';

/**
 * Vidya EduCare - Production Infrastructure Rules
 * Target Instance: vidyaeducaredatabase
 * Deployment Salt: V65_RELIABLE_ADMIN_BOOTSTRAP
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isMaster() {
      // Prioritize email-based identification for the master account to avoid project-specific UID issues
      return signedIn() && (
        request.auth.token.email == 'admin@vidyaeducare.com'
      );
    }

    function isAdmin() {
      if (!signedIn()) return false;
      if (isMaster()) return true;
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && (
        get(adminPath).data.status == 'Active' || 
        get(adminPath).data.role == 'Head Admin'
      );
    }

    // --- SUPREME OVERRIDE ---
    // Masters have full access to everything for infrastructure management.
    match /{allPaths=**} {
      allow read, write: if isMaster();
    }

    // --- USER PRIVATE DATA ---

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(uid);
      allow update, delete: if isOwner(uid) || isAdmin();
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if signedIn() && isOwner(uid);
      allow update: if isAdmin() || isOwner(uid);
    }

    match /activationCodes/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /chats/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
      match /messages/{mid} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /referbolt/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    // --- SHARED DATA ---

    match /configs/{document=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn();
      allow write: if isAdmin() || isOwner(uid);
    }

    match /students/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin() || (resource != null && resource.data.parentId == request.auth.uid) || (request.resource != null && request.resource.data.parentId == request.auth.uid);
    }
    
    match /transactions/{id} {
      allow read, list: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
    }

    match /testSets/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }

    match /scheduledTests/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }

    match /testResults/{id} {
      allow read, list: if signedIn();
      allow create: if signedIn();
    }

    match /leaderboard/{id} {
      allow read, list: if true;
      allow write: if signedIn();
    }

    match /quizClashTournaments/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /quizClashResults/{id} {
      allow read, list: if true;
      allow write: if signedIn();
    }
    
    match /notifications/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }
    
    match /clients/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin();
    }
  }
}