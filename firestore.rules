rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * SUPREME BOOTSTRAP AUTHORITY (FINAL OVERRIDE)
     * Explicitly hardcoded for the master identities to bypass all initial setup locks.
     */
    match /{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == '1JgG0oF1D6YREaxOCSGedIfpQZ42' ||
        request.auth.token.email == 'admin@vidyaeducare.com' ||
        request.auth.token.email == 'student@vidyaeducare.com'
      );
    }

    // Core helper functions for standard users
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      if (!isAuthenticated()) return false;
      if (request.auth.token.email == 'admin@vidyaeducare.com') return true;
      if (request.auth.uid == '1JgG0oF1D6YREaxOCSGedIfpQZ42') return true;
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && (
             get(adminPath).data.status == 'Active' ||
             get(adminPath).data.role == 'Head Admin'
      );
    }

    function isHeadAdmin() {
      if (!isAuthenticated()) return false;
      if (request.auth.token.email == 'admin@vidyaeducare.com') return true;
      if (request.auth.uid == '1JgG0oF1D6YREaxOCSGedIfpQZ42') return true;
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && get(adminPath).data.role == 'Head Admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /admins/{userId} {
      allow read, list: if isAuthenticated();
      allow write: if isHeadAdmin() || isOwner(userId);
    }

    match /users/{userId} {
      allow read, list: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    match /wallets/{userId} {
      allow read, list: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    match /students/{studentId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin() || (resource != null && resource.data.parentId == request.auth.uid);
    }
    
    match /transactions/{txId} {
        allow read, list: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.user == request.auth.uid;
        allow update: if isHeadAdmin();
    }

    match /chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isHeadAdmin();
    }

    match /activationCodes/{userId} {
        allow read, write: if isOwner(userId) || isAdmin();
    }

    match /testSets/{testSetId} {
        allow read: if true;
        allow write: if isHeadAdmin();
    }

    match /scheduledTests/{testId} {
        allow read: if true;
        allow write: if isHeadAdmin();
    }

    match /testResults/{resultId} {
        allow create: if isAuthenticated();
        allow read: if isAuthenticated();
    }

    match /leaderboard/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated(); 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated();
    }
    
    match /notifications/{notifId} {
        allow read, list: if isAuthenticated();
        allow write: if isAdmin();
    }
    
    match /referbolt/{userId} {
        allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /clients/{clientId} {
        allow read, list: if isAuthenticated();
        allow write: if isAdmin();
    }
  }
}