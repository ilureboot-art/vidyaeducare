rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core helper functions for security
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // BOOTSTRAP OVERRIDE: Identifies the master accounts by email token.
    // This is the most reliable way to authorize initialization before DB records exist.
    function isBootstrap() {
      return isAuthenticated() && 
             (request.auth.token.email == 'admin@vidyaeducare.com' || 
              request.auth.token.email == 'student@vidyaeducare.com');
    }

    // Robust check: ensures document exists before accessing properties
    function isAdmin() {
      if (!isAuthenticated()) return false;
      if (isBootstrap()) return true; 
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && (
             get(adminPath).data.status == 'Active' ||
             get(adminPath).data.role == 'Head Admin'
      );
    }

    function isHeadAdmin() {
      if (!isAuthenticated()) return false;
      if (isBootstrap()) return true;

      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && get(adminPath).data.role == 'Head Admin';
    }

    match /admins/{userId} {
      allow read, list: if isAuthenticated();
      // Allow bootstrap identity or Head Admins to manage admin records
      allow write, delete: if isBootstrap() || isHeadAdmin() || isOwner(userId);
    }

    match /users/{userId} {
      allow read, list: if isBootstrap() || isAdmin() || isOwner(userId);
      allow write: if isBootstrap() || isOwner(userId) || isAdmin();
    }

    match /wallets/{userId} {
      allow read, list: if isBootstrap() || isAdmin() || isOwner(userId);
      allow write: if isBootstrap() || isOwner(userId) || isAdmin();
    }

    match /students/{studentId} {
      allow read, list: if isAuthenticated();
      allow write: if isBootstrap() || isAdmin() || (resource != null && resource.data.parentId == request.auth.uid);
    }
    
    match /transactions/{txId} {
        allow read, list: if isAuthenticated();
        allow create: if isAuthenticated() && (request.resource.data.user == request.auth.uid || isBootstrap());
        allow update: if isHeadAdmin() || isBootstrap();
    }

    match /chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isHeadAdmin() || isBootstrap();
    }

    match /activationCodes/{userId} {
        allow read, write: if isOwner(userId) || isAdmin() || isBootstrap();
    }

    match /testSets/{testSetId} {
        allow read: if true;
        allow write: if isHeadAdmin() || isBootstrap();
    }

    match /scheduledTests/{testId} {
        allow read: if true;
        allow write: if isHeadAdmin() || isBootstrap();
    }

    match /testResults/{resultId} {
        allow create: if isAuthenticated();
        allow read: if isAuthenticated() && (
          isAdmin() || resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.students
        );
    }

    match /leaderboard/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated(); 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read: if true;
        allow write: if isAdmin() || isBootstrap();
    }

    match /quizClashResults/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated();
    }
    
    match /notifications/{notifId} {
        allow read, list: if isAuthenticated();
        allow write: if isAdmin() || isBootstrap();
    }
    
    match /referbolt/{userId} {
        allow read, write: if isOwner(userId) || isAdmin() || isBootstrap();
    }
    
    match /clients/{clientId} {
        allow read, list: if isAuthenticated();
        allow write: if isAdmin() || isBootstrap();
    }
  }
}