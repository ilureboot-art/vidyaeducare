
rules_version = '2';

/**
 * Vidya EduCare - High Performance Production Rules
 * Priority: Absolute Master Admin Supreme Bypass
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    function isMaster() {
      // Faster, simplified Master Admin check for high-performance resolution
      return signedIn() && 
        (request.auth.token.email.lower() == 'admin@vidyaeducare.com' || request.auth.token.email.lower() == 'headadmin@vidyaeducare.com');
    }

    function isAdmin() {
      if (!signedIn()) return false;
      if (isMaster()) return true;
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- SUPREME OVERRIDE (PRIORITY 1) ---
    match /{allPaths=**} {
      allow read, write: if isMaster();
    }

    // --- GLOBAL CONFIGURATIONS ---
    match /configs/{document=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- USER PRIVATE DATA ---
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if true; // Allow new users to create profiles during signup
      allow update, delete: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /wallets/{uid} {
      // CRITICAL: Allow public read/list for referral code verification during guest signup
      allow read, list: if true;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isAdmin() || isOwner(uid);
    }

    match /activationCodes/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn();
      allow write: if isMaster();
    }

    match /chats/{uid} {
      allow read, write, list: if isOwner(uid) || isAdmin();
      match /messages/{mid} {
        allow read, write, list: if isOwner(uid) || isAdmin();
      }
    }

    match /referbolt/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid) || isAdmin();
      allow create: if signedIn() && request.auth.uid == uid;
    }

    match /students/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin() || (resource != null && (resource.data.parentId == request.auth.uid)) || (request.resource != null && (request.resource.data.parentId == request.auth.uid));
    }
    
    match /transactions/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && resource.data.user == request.auth.uid));
      allow create: if true; // Allow signup bonus transactions
      allow update: if isAdmin();
    }

    match /testSets/{id} {
      allow read: if true; // Allow students to read questions
      allow list: if true;
      allow write: if isAdmin();
    }

    match /scheduledTests/{id} {
      allow read, list: if true; // Allow public schedule viewing
      allow write: if isAdmin();
    }

    match /testResults/{id} {
      allow read, list: if signedIn();
      allow create: if signedIn();
    }

    match /leaderboard/{id} {
      allow read, list: if true;
      allow write: if true;
    }

    match /quizClashTournaments/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /quizClashResults/{id} {
      allow read, list: if true;
      allow write: if true;
    }
    
    match /notifications/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin')));
      allow write: if true; // Allow signup notifications
    }
    
    match /clients/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin() || true;
    }
  }
}
