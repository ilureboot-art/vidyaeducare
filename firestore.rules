rules_version = '2';

/**
 * Vidya EduCare - Supreme Infrastructure Rules
 * Target Instance: vidyaeducaredatabase
 * Deployment Salt: V25_EXPLICIT_CHAT_LISTING
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- SUPREME BOOTSTRAP AUTHORITY ---
    // Explicit global bypass for infrastructure setup and master admin access.
    match /{allPaths=**} {
      allow read, write, list: if request.auth != null && (
        request.auth.uid == '1JgG0oF1D6YREaxOCSGedIfpQZ42' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'admin@vidyaeducare.com') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'student@vidyaeducare.com')
      );
    }

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      if (!isAuthenticated()) return false;
      
      // Direct Master Check
      if (request.auth.uid == '1JgG0oF1D6YREaxOCSGedIfpQZ42' || 
         (request.auth.token.email != null && request.auth.token.email.lower() == 'admin@vidyaeducare.com')) {
        return true;
      }
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && get(adminPath).data.status == 'Active';
    }

    function isHeadAdmin() {
      if (!isAuthenticated()) return false;
      if (request.auth.uid == '1JgG0oF1D6YREaxOCSGedIfpQZ42' || 
         (request.auth.token.email != null && request.auth.token.email.lower() == 'admin@vidyaeducare.com')) {
        return true;
      }
      
      let adminPath = /databases/$(database)/documents/admins/$(request.auth.uid);
      return exists(adminPath) && get(adminPath).data.role == 'Head Admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collection Specific Rules ---

    match /admins/{userId} {
      allow read, list: if isAuthenticated();
      allow write: if isHeadAdmin() || isOwner(userId);
    }

    match /users/{userId} {
      allow read, list: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    match /wallets/{userId} {
      allow read, list: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    match /students/{studentId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin() || (resource != null && resource.data.parentId == request.auth.uid);
    }
    
    match /transactions/{txId} {
        allow read, list: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isHeadAdmin();
    }

    // Support Chat Rules
    // Explicitly allow administrators to list all chats at the collection level.
    match /chats {
      allow list: if isAdmin();
      
      match /{userId} {
        allow read, write: if isOwner(userId) || isAdmin();
        
        match /messages/{messageId} {
          allow read, write, list: if isOwner(userId) || isAdmin();
        }
      }
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isHeadAdmin();
    }

    match /activationCodes/{userId} {
        allow read, write, list: if isOwner(userId) || isAdmin();
    }

    match /testSets/{testSetId} {
        allow read, list: if true;
        allow write: if isHeadAdmin();
    }

    match /scheduledTests/{testId} {
        allow read, list: if true;
        allow write: if isHeadAdmin();
    }

    match /testResults/{resultId} {
        allow create, read, list: if isAuthenticated();
    }

    match /leaderboard/{resultId} {
        allow read, list: if true;
        allow write: if isAuthenticated(); 
    }

    match /quizClashTournaments/{tournamentId} {
        allow read, list: if true;
        allow write: if isAdmin();
    }

    match /quizClashResults/{resultId} {
        allow read, list: if true;
        allow write: if isAuthenticated();
    }
    
    match /notifications/{notifId} {
        allow read, list: if isAuthenticated();
        allow write: if isAdmin();
    }
    
    match /referbolt/{userId} {
        allow read, write, list: if isOwner(userId) || isAdmin();
    }
    
    match /clients/{clientId} {
        allow read, list: if isAuthenticated();
        allow write: if isAdmin();
    }
  }
}