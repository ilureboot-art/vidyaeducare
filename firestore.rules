
rules_version = '2';

/**
 * Vidya EduCare - Elite Production Security Rules
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return signedIn() && 
        (request.auth.token.email.lower() == 'admin@vidyaeducare.com' || request.auth.token.email.lower() == 'headadmin@vidyaeducare.com');
    }

    function isAdmin() {
      if (!signedIn()) return false;
      if (isMaster()) return true;
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- GLOBAL CONFIGURATIONS (High Priority) ---
    // Explicitly public for system-wide consistency (Pricing, Banks, Academic Rules)
    match /configs/{document=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- MASTER OVERRIDE ---
    match /{allPaths=**} {
      allow read, write: if isMaster();
    }

    // --- USER PROFILE & ACCESS ---
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if true;
      allow update, delete: if isOwner(uid) || isAdmin();
    }

    match /wallets/{uid} {
      allow read, list: if true; // Public for referral verification
      allow create: if isOwner(uid);
      allow update: if isAdmin() || isOwner(uid);
    }

    match /activationCodes/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn();
      allow write: if isMaster();
    }

    match /chats/{uid} {
      allow read, write, list: if isOwner(uid) || isAdmin();
      match /messages/{mid} {
        allow read, write, list: if isOwner(uid) || isAdmin();
      }
    }

    match /referbolt/{uid} {
      allow read, list: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
    }

    match /students/{id} {
      allow read, list: if signedIn();
      allow write: if isAdmin() || (resource != null && resource.data.parentId == request.auth.uid) || (request.resource != null && request.resource.data.parentId == request.auth.uid);
    }
    
    match /transactions/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && resource.data.user == request.auth.uid));
      allow create: if true;
      allow update: if isAdmin();
    }

    match /testSets/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /scheduledTests/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /testResults/{id} {
      allow read, list, create: if signedIn();
    }

    match /leaderboard/{id} {
      allow read, list, write: if true;
    }

    match /quizClashTournaments/{id} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /quizClashResults/{id} {
      allow read, list, write: if true;
    }
    
    match /notifications/{id} {
      allow read, list: if signedIn() && (isAdmin() || (resource != null && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin')));
      allow write: if true;
    }
    
    match /clients/{id} {
      allow read, list: if signedIn();
      allow write: if true;
    }
  }
}
